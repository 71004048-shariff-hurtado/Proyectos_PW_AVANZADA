# Variables de entorno del proyecto EduTech
# Copia este archivo en cada backend como ".env" y completa los valores

# ── Backend Auth/Usuarios (proyecto-node-mongodb) ──────────────
# Puerto en el que correrá el servidor
PORT=3000

# Cadena de conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_base_datos>?retryWrites=true&w=majority

# Clave secreta para firmar tokens JWT (mín. 32 caracteres aleatorios)
# DEBE SER LA MISMA en ambos backends
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria_de_al_menos_32_caracteres

# URLs de frontends permitidos en CORS (dejar vacío en desarrollo local)
FRONTEND_URL_REACT=https://tu-app-react.vercel.app
FRONTEND_URL_ANGULAR=https://tu-app-angular.vercel.app

# ── Backend Cursos/Docentes (api-cursos) ──────────────────────
# (Para ese backend, cambiar PORT=3001 y usar el mismo JWT_SECRET)

# ── Next.js ──────────────────────────────────────────────────
# URL pública del backend de cursos (para que Next.js haga fetch en SSR/SSG)
NEXT_PUBLIC_CURSOS_API=https://tu-api-cursos.onrender.com/api
