# Variables de entorno — Servidor Cursos/Docentes (api-cursos)
# Copia este archivo como .env y rellena los valores reales

PORT=3001
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_base_datos>?retryWrites=true&w=majority
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria

# IMPORTANTE: JWT_SECRET debe ser el mismo en ambos servidores
# URLs de frontends para CORS
FRONTEND_URL_REACT=
FRONTEND_URL_ANGULAR=
FRONTEND_URL_NEXT=
