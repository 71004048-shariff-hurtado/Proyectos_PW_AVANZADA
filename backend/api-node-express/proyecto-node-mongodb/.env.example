# Variables de entorno — Servidor Auth/Usuarios (proyecto-node-mongodb)
# Copia este archivo como .env y rellena los valores reales

PORT=3000
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_base_datos>?retryWrites=true&w=majority
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria

# URLs de frontends para CORS (Dejar vacío en desarrollo local)
FRONTEND_URL_REACT=
FRONTEND_URL_ANGULAR=
